// ============================================================
//  STOCKPILOT — Firestore Security Rules
//  Paste these into Firebase Console → Firestore → Rules
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isLoggedIn() {
      return request.auth != null;
    }

    // INVENTORY: logged-in users can read & create; only admins can update/delete
    match /inventory/{itemId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // USERS: only admins can read/write user profiles
    match /users/{userId} {
      allow read:   if isLoggedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isLoggedIn();
      allow update: if isAdmin() || request.auth.uid == userId;
      allow delete: if isAdmin();
    }
  }
}
